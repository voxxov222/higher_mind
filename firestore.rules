rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    match /test/connection {
      allow read: if true;
    }

    function isValidUserCosmicProfile(data) {
      return data.keys().hasAll(['userId', 'updatedAt'])
        && data.userId is string && data.userId.size() <= 128
        && data.userId == request.auth.uid
        && data.updatedAt == request.time;
    }

    function isValidCommunityPost(data) {
      return data.keys().hasAll(['userId', 'username', 'timestamp', 'type', 'title', 'content'])
        && data.userId == request.auth.uid
        && data.timestamp == request.time;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['senderId', 'recipientId', 'timestamp', 'content'])
        && data.senderId == request.auth.uid
        && data.timestamp == request.time;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId);
      allow list: if isSignedIn();

      allow create: if isOwner(userId) && isValidId(userId) 
        && isValidUserCosmicProfile(incoming());

      allow update: if isOwner(userId) && isValidId(userId) 
        && isValidUserCosmicProfile(incoming()) 
        && incoming().diff(existing()).affectedKeys().hasOnly(['userId', 'username', 'displayName', 'input', 'cosmicData', 'profileConfig', 'holographicConfig', 'astrology', 'bio', 'updatedAt']);

      allow delete: if false;
    }

    match /community_posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(postId) && isValidCommunityPost(incoming());
      allow update: if isSignedIn() && isValidId(postId) && (
        (isOwner(existing().userId) && isValidCommunityPost(incoming())) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['likes']))
      );
      allow delete: if isOwner(existing().userId);
    }

    match /swarm_findings/{findingId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isOwner(resource.data.userId) && isOwner(request.resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }

    match /messages/{messageId} {
      allow read: if isSignedIn() && (isOwner(existing().senderId) || isOwner(existing().recipientId));
      allow create: if isSignedIn() && isValidId(messageId) && isValidMessage(incoming());
      allow update: if isSignedIn() && (isOwner(existing().senderId) || isOwner(existing().recipientId)) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['read', 'astralContext'])
      );
      allow delete: if isOwner(existing().senderId);
    }
  }
}
